# Versions
ETCD_VERSION=v3.5.12
NGINX_VERSION=1.25-alpine
PROMETHEUS_VERSION=v2.51.0
GRAFANA_VERSION=10.4.0
CADVISOR_VERSION=v0.49.1
PGADMIN_VERSION=8.5
PYTHON_VERSION=3.12-slim
SPILO_VERSION=3.3-p1
POSTGRES_EXPORTER_VERSION=v0.15.0

# PostgreSQL / Patroni
POSTGRES_DB=meteo_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_HOST=postgres1
POSTGRES_PORT=5432

PATRONI_SCOPE=meteo-cluster
PATRONI_REPLICATION_USER=replicator
PATRONI_REPLICATION_PASSWORD=changeme
PATRONI_SUPERUSER_PASSWORD=changeme

# Sharding
DB_SHARD_NORD_HOST=postgres1
DB_SHARD_SUD_HOST=postgres3
DB_PORT=5432

# postgres_exporter
DATA_SOURCE_NAME=postgresql://postgres:changeme@postgres1:5432/meteo_db?sslmode=disable

# ETCD
ETCD_INITIAL_CLUSTER_TOKEN=meteo-etcd-token

# Backend
DATA_SERVICE_URL=http://data_service:8001
WORKER_INTERVAL=300000
PORT=3000

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme

# pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=changeme
